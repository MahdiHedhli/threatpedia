---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    eventId: string;
    title: string;
    date: Date;
    attackType: string;
    severity: string;
    sector: string;
    geography: string;
    threatActor: string;
    attributionConfidence: string;
    reviewStatus: string;
    confidenceGrade: string;
    cves: string[];
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title}>
  <article class="container">
    <header class="article-header">
      <div class="incident-header">
        <span class="incident-id">{frontmatter.eventId}</span>
        <span class={`severity ${frontmatter.severity}`}>{frontmatter.severity}</span>
        <span class="review-status">{frontmatter.reviewStatus}</span>
      </div>
      <h1>{frontmatter.title}</h1>
      <div class="incident-meta">
        <div class="meta-item">
          <span class="meta-label">Date</span>
          <span class="meta-value">{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Attack Type</span>
          <span class="meta-value">{frontmatter.attackType}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Sector</span>
          <span class="meta-value">{frontmatter.sector}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Geography</span>
          <span class="meta-value">{frontmatter.geography}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Threat Actor</span>
          <span class="meta-value">{frontmatter.threatActor}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Attribution</span>
          <span class="meta-value">{frontmatter.attributionConfidence}</span>
        </div>
        {frontmatter.cves.length > 0 && (
          <div class="meta-item">
            <span class="meta-label">CVEs</span>
            <span class="meta-value">{frontmatter.cves.join(', ')}</span>
          </div>
        )}
        <div class="meta-item">
          <span class="meta-label">Confidence</span>
          <span class="meta-value">{frontmatter.confidenceGrade}</span>
        </div>
      </div>
    </header>

    <div class="content">
      <slot />
    </div>

    {frontmatter.tags.length > 0 && (
      <div class="tags">
        {frontmatter.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </article>
</Base>
