---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    eventId: string;
    title: string;
    date: Date;
    attackType: string;
    severity: string;
    sector: string;
    geography: string;
    threatActor: string;
    attributionConfidence: string;
    reviewStatus: string;
    confidenceGrade: string;
    cves: string[];
    tags: string[];
  };
}

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title}>
  <article>
    <header class="incident-header">
      <span class="incident-id">{frontmatter.eventId}</span>
      <span class={`severity ${frontmatter.severity}`}>
        {frontmatter.severity}
      </span>
      <span class="review-status">{frontmatter.reviewStatus}</span>
    </header>

    <h1>{frontmatter.title}</h1>

    <div class="meta">
      <dl>
        <dt>Date</dt><dd>{new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</dd>
        <dt>Attack Type</dt><dd>{frontmatter.attackType}</dd>
        <dt>Sector</dt><dd>{frontmatter.sector}</dd>
        <dt>Geography</dt><dd>{frontmatter.geography}</dd>
        <dt>Threat Actor</dt><dd>{frontmatter.threatActor}</dd>
        <dt>Attribution</dt><dd>{frontmatter.attributionConfidence}</dd>
        {frontmatter.cves.length > 0 && (
          <><dt>CVEs</dt><dd>{frontmatter.cves.join(', ')}</dd></>
        )}
      </dl>
    </div>

    <div class="content">
      <slot />
    </div>

    {frontmatter.tags.length > 0 && (
      <div class="tags">
        {frontmatter.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </article>
</Base>
