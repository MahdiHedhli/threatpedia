---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The Definitive Cyber Threat Encyclopedia' } = Astro.props;

// Build ticker items from all collections
interface TickerItem {
  label: string;
  href: string;
  severity: string;
  badge: string;
}

const tickerItems: TickerItem[] = [];

const severityOrder: Record<string, number> = { critical: 0, high: 1, medium: 2, low: 3 };

try {
  const [incidents, campaigns, actors, zeroDays] = await Promise.all([
    getCollection('incidents'),
    getCollection('campaigns').catch(() => []),
    getCollection('threat-actors'),
    getCollection('zero-days'),
  ]);

  // Zero-days first (most urgent)
  zeroDays
    .sort((a, b) => (severityOrder[a.data.severity] ?? 9) - (severityOrder[b.data.severity] ?? 9))
    .slice(0, 4)
    .forEach((z) => {
      tickerItems.push({
        label: z.data.title,
        href: `/zero-days/${z.id}/`,
        severity: z.data.severity,
        badge: z.data.status === 'active' ? '0-DAY' : z.data.severity.toUpperCase(),
      });
    });

  // Recent incidents
  incidents
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 5)
    .forEach((i) => {
      tickerItems.push({
        label: i.data.title,
        href: `/incidents/${i.id}/`,
        severity: i.data.severity,
        badge: i.data.severity.toUpperCase(),
      });
    });

  // Active campaigns
  campaigns
    .filter((c) => c.data.ongoing)
    .slice(0, 3)
    .forEach((c) => {
      tickerItems.push({
        label: c.data.title,
        href: `/campaigns/${c.id}/`,
        severity: c.data.severity,
        badge: 'CAMPAIGN',
      });
    });

  // Notable threat actors
  actors
    .filter((a) => a.data.status === 'active')
    .slice(0, 3)
    .forEach((a) => {
      tickerItems.push({
        label: a.data.name,
        href: `/threat-actors/${a.id}/`,
        severity: 'high',
        badge: 'APT',
      });
    });
} catch { /* collections may be empty during build */ }
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080b10" />
    <link rel="icon" type="image/svg+xml" href="/tp-favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title} — Threatpedia</title>
  </head>
  <body>
    <nav>
      <a class="nav-logo" href="/">
        <img class="nav-logo-icon" src="/tp-logo.svg" alt="TP" width="32" height="32" />
        <span class="nav-logo-text">Threat<span>pedia</span></span>
      </a>
      {tickerItems.length > 0 ? (
        <div class="nav-ticker">
          <div class="ticker-track">
            {tickerItems.map((item) => (
              <a class="ticker-item" href={item.href}>
                <span class={`ticker-badge ticker-${item.severity}`}>{item.badge}</span>
                <span>{item.label}</span>
              </a>
            ))}
            {/* Duplicate for seamless loop */}
            {tickerItems.map((item) => (
              <a class="ticker-item" href={item.href} aria-hidden="true">
                <span class={`ticker-badge ticker-${item.severity}`}>{item.badge}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="nav-status">
          <div class="status-dot"></div>
          BUILDING IN PUBLIC
        </div>
      )}
      <button class="hamburger" id="hamburger-btn" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <div class="menu-overlay" id="menu-overlay"></div>
    <div class="menu-panel" id="menu-panel">
      <div class="menu-label">Search</div>
      <div class="search-wrapper">
        <input class="menu-search" type="text" placeholder="Search Threatpedia..." id="menu-search" />
        <div class="search-results" id="search-results"></div>
      </div>
      <div class="menu-label">Navigate</div>
      <div class="menu-links">
        <a href="/">Home</a>
        <a href="/incidents/">Incidents</a>
        <a href="/campaigns/">Campaigns</a>
        <a href="/threat-actors/">Threat Actors</a>
        <a href="/zero-days/">Zero-Days</a>
        <a href="/roadmap/">Roadmap</a>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-logo">THREATPEDIA</div>
      <div class="footer-domains">
        <div class="footer-domain">threatpedia.wiki</div>
        <div class="footer-domain">threatpedia.net</div>
      </div>
      <div class="footer-copy">&copy; 2026 — All Rights Reserved</div>
    </footer>

    <script>
      // ── Hamburger menu ──────────────────────────────────────────────────
      const btn = document.getElementById('hamburger-btn');
      const overlay = document.getElementById('menu-overlay');
      const panel = document.getElementById('menu-panel');
      const searchInput = document.getElementById('menu-search');

      function toggleMenu() {
        const isOpen = panel.classList.toggle('open');
        overlay.classList.toggle('open');
        btn.classList.toggle('open');
        if (isOpen && searchInput) searchInput.focus();
      }

      function closeMenu() {
        panel.classList.remove('open');
        overlay.classList.remove('open');
        btn.classList.remove('open');
      }

      btn.addEventListener('click', toggleMenu);
      overlay.addEventListener('click', closeMenu);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

      // ── Ticker scroll speed ─────────────────────────────────────────────
      const tickerTrack = document.querySelector('.ticker-track');
      if (tickerTrack) {
        requestAnimationFrame(() => {
          const halfWidth = tickerTrack.scrollWidth / 2;
          const duration = halfWidth / 40; // 40px/sec
          tickerTrack.style.setProperty('--ticker-duration', duration + 's');
        });
      }

      // ── Highlight active nav link ───────────────────────────────────────
      document.querySelectorAll('.menu-links a').forEach((a) => {
        if (window.location.pathname === a.getAttribute('href') ||
            (a.getAttribute('href') !== '/' && window.location.pathname.startsWith(a.getAttribute('href')))) {
          a.classList.add('active');
        }
      });

      // ── Sitewide search ─────────────────────────────────────────────────
      let searchIndex = null;
      const resultsEl = document.getElementById('search-results');
      let searchTimeout;

      async function loadSearchIndex() {
        if (searchIndex) return searchIndex;
        try {
          const res = await fetch('/search-index.json');
          searchIndex = await res.json();
        } catch { searchIndex = []; }
        return searchIndex;
      }

      function escapeHtml(t) {
        const d = document.createElement('div');
        d.textContent = t;
        return d.innerHTML;
      }

      function doSearch(query) {
        if (!searchIndex || !query) { resultsEl.style.display = 'none'; return; }
        const q = query.toLowerCase();
        const matches = searchIndex
          .map((item) => {
            let score = 0;
            const title = (item.title || '').toLowerCase();
            const name = (item.name || '').toLowerCase();
            const label = title || name;
            if (label.startsWith(q)) score += 100;
            else if (label.includes(q)) score += 50;
            if (item.aliases) {
              for (const a of item.aliases) {
                if (a.toLowerCase().includes(q)) score += 30;
              }
            }
            if (item.attackType && item.attackType.toLowerCase().includes(q)) score += 20;
            if (item.sector && item.sector.toLowerCase().includes(q)) score += 15;
            if (item.cve && item.cve.toLowerCase().includes(q)) score += 40;
            return { ...item, score };
          })
          .filter((r) => r.score > 0)
          .sort((a, b) => b.score - a.score)
          .slice(0, 12);

        if (matches.length === 0) { resultsEl.style.display = 'none'; return; }

        const severityColor = { critical: '#ff4444', high: '#ffa500', medium: '#e8a020', low: '#51cf66' };
        let html = '';
        let lastType = '';
        for (const m of matches) {
          if (m.type !== lastType) {
            lastType = m.type;
            const label = m.type === 'incident' ? 'INCIDENTS' : m.type === 'threat-actor' ? 'THREAT ACTORS' : 'ZERO-DAYS';
            html += `<div class="sr-category">${label}</div>`;
          }
          const title = escapeHtml(m.title || m.name || '');
          const sev = m.severity ? `<span class="sr-severity" style="color:${severityColor[m.severity] || '#e8a020'}">${escapeHtml(m.severity)}</span>` : '';
          const sub = m.type === 'threat-actor'
            ? `${escapeHtml(m.affiliation || '')} &middot; ${escapeHtml(m.motivation || '')}`
            : m.type === 'incident'
            ? `${escapeHtml(m.sector || '')} &middot; ${escapeHtml(m.attackType || '')}`
            : `${escapeHtml(m.cve || '')} &middot; ${escapeHtml(m.platform || '')}`;
          html += `<a class="sr-item" href="${m.url}"><div class="sr-title">${title}${sev}</div><div class="sr-sub">${sub}</div></a>`;
        }
        resultsEl.innerHTML = html;
        resultsEl.style.display = 'block';
      }

      searchInput.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        const q = searchInput.value.trim();
        if (!q) { resultsEl.style.display = 'none'; return; }
        searchTimeout = setTimeout(async () => {
          await loadSearchIndex();
          doSearch(q);
        }, 150);
      });

      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { resultsEl.style.display = 'none'; }
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── Variables ─────────────────────────────────────────────────────────── */
  :root {
    --bg:        #080b10;
    --surface:   #0d1117;
    --border:    #1e2733;
    --amber:     #e8a020;
    --amber-dim: #a06a10;
    --text:      #cdd5e0;
    --muted:     #5a6a7e;
    --white:     #f0f4f8;
    --severity-critical: #ff4444;
    --severity-high: #ffa500;
    --severity-medium: #e8a020;
    --severity-low: #51cf66;
    --font-serif: 'Playfair Display', serif;
    --font-sans: 'IBM Plex Sans', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
    --max-width: 1400px;
  }

  /* ── Reset ──────────────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* ── Grid overlay ───────────────────────────────────────────────────────── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(232,160,32,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,160,32,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Noise texture ──────────────────────────────────────────────────────── */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Navigation ─────────────────────────────────────────────────────────── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    background: rgba(8, 11, 16, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  @media (min-width: 768px) { nav { padding: 20px 48px; } }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    gap: 10px;
    flex-shrink: 0;
  }

  .nav-logo:hover { text-decoration: none; }

  .nav-logo-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: block;
  }

  .nav-logo-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    color: var(--amber);
    text-transform: uppercase;
  }

  .nav-logo-text span { color: var(--muted); }

  @media (max-width: 767px) { .nav-logo-text { display: none; } }

  .nav-status {
    display: none;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  @media (min-width: 768px) { .nav-status { display: flex; } }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--amber);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.25; } }

  /* ── Threat Ticker ─────────────────────────────────────────────────────── */
  .nav-ticker {
    display: none;
    flex: 1;
    margin: 0 24px;
    overflow: hidden;
    height: 22px;
    align-items: center;
    position: relative;
    mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent);
  }

  @media (min-width: 768px) { .nav-ticker { display: flex; } }

  .ticker-track {
    display: flex;
    gap: 32px;
    white-space: nowrap;
    animation: ticker-scroll var(--ticker-duration, 60s) linear infinite;
  }

  .ticker-track:hover { animation-play-state: paused; }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .ticker-item:hover { color: var(--white); text-decoration: none; }

  .ticker-badge {
    display: inline-block;
    padding: 1px 6px;
    font-size: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2px;
    line-height: 1.4;
  }

  .ticker-critical { background: var(--severity-critical); color: #fff; }
  .ticker-high { background: var(--amber); color: var(--bg); }
  .ticker-medium { background: var(--muted); color: var(--white); }
  .ticker-low { background: var(--border); color: var(--text); }

  /* ── Hamburger ──────────────────────────────────────────────────────────── */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    background: none;
    border: 1px solid var(--border);
    padding: 5px;
    cursor: pointer;
    transition: border-color 0.2s;
    flex-shrink: 0;
  }

  .hamburger:hover { border-color: var(--amber); }

  .hamburger span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--amber);
    transition: transform 0.3s, opacity 0.3s;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(3.25px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-3.25px) rotate(-45deg); }

  /* ── Slide-out menu ─────────────────────────────────────────────────────── */
  .menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .menu-overlay.open { opacity: 1; pointer-events: auto; }

  .menu-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 320px;
    max-width: 85vw;
    background: var(--surface);
    border-left: 1px solid var(--border);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    padding: 80px 32px 32px;
    overflow-y: auto;
  }

  .menu-panel.open { transform: translateX(0); }

  .menu-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--amber-dim);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .menu-search {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--white);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    margin-bottom: 0;
    border-radius: 0;
  }

  .menu-search::placeholder { color: var(--muted); }
  .menu-search:focus { border-color: var(--amber); box-shadow: 0 0 0 1px var(--amber); }

  .search-wrapper {
    position: relative;
    margin-bottom: 28px;
  }

  .search-results {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    max-height: 400px;
    overflow-y: auto;
    z-index: 1000;
  }

  .sr-category {
    padding: 8px 16px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--amber-dim);
    text-transform: uppercase;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .sr-item {
    display: block;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s;
  }

  .sr-item:hover { background: var(--surface); text-decoration: none; }

  .sr-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }

  .sr-severity {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .sr-sub {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 2px;
  }

  .menu-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 28px;
  }

  .menu-links a {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--text);
    text-decoration: none;
    text-transform: uppercase;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s, padding-left 0.2s;
  }

  .menu-links a:first-child { border-top: 1px solid var(--border); }
  .menu-links a:hover { color: var(--amber); padding-left: 8px; text-decoration: none; }
  .menu-links a.active { color: var(--amber); }

  /* ── Main content ───────────────────────────────────────────────────────── */
  main {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    padding-top: 104px;
    width: 100%;
    flex: 1;
  }

  /* ── Typography ─────────────────────────────────────────────────────────── */
  h1 {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--white);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--amber);
    letter-spacing: -0.3px;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--white);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  p {
    margin-bottom: 1rem;
    color: var(--text);
    line-height: 1.7;
  }

  a {
    color: var(--amber);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: #f0b030;
    text-decoration: underline;
  }

  strong { color: var(--white); font-weight: 500; }

  code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg);
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--amber);
  }

  pre {
    background: var(--surface) !important;
    border: 1px solid var(--border);
    border-left: 3px solid var(--amber);
    border-radius: 4px;
    padding: 16px;
    overflow-x: auto;
    margin: 16px 0;
  }

  pre code {
    background: none;
    padding: 0;
    color: var(--text);
  }

  blockquote {
    border-left: 3px solid var(--amber);
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    background: var(--surface);
    border-radius: 0 4px 4px 0;
    color: var(--text);
  }

  ul, ol {
    margin: 0.5rem 0 1rem 1.5rem;
    color: var(--text);
  }

  li { margin-bottom: 0.25rem; }

  /* ── Tables ─────────────────────────────────────────────────────────────── */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
    background: var(--surface);
