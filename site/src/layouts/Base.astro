    transition: color 0.2s, padding-left 0.2s;
  }

  .menu-links a:first-child { border-top: 1px solid var(--border); }
  .menu-links a:hover { color: var(--amber); padding-left: 8px; text-decoration: none; }
  .menu-links a.active { color: var(--amber); }

  /* ── Main content ───────────────────────────────────────────────────────── */
  main {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    padding-top: 104px;
    width: 100%;
    flex: 1;
  }

  /* ── Typography ─────────────────────────────────────────────────────────── */
  h1 {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--white);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--amber);
    letter-spacing: -0.3px;
  }

  h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--white);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  p {
    margin-bottom: 1rem;
    color: var(--text);
    line-height: 1.7;
  }

  a {
    color: var(--amber);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: #f0b030;
    text-decoration: underline;
  }

  strong { color: var(--white); font-weight: 500; }

  code {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg);
    padding: 2px 6px;
    border-radius: 3px;
    color: var(--amber);
  }

  pre {
    background: var(--surface) !important;
    border: 1px solid var(--border);
    border-left: 3px solid var(--amber);
    border-radius: 4px;
    padding: 16px;
    overflow-x: auto;
    margin: 16px 0;
  }

  pre code {
    background: none;
    padding: 0;
    color: var(--text);
  }

  blockquote {
    border-left: 3px solid var(--amber);
    margin: 1rem 0;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border-radius: 0 4px 4px 0;
    color: var(--text);
    overflow-wrap: break-word;
    word-break: break-word;
  }

  ul, ol {
    margin: 0.5rem 0 1rem 1.5rem;
    color: var(--text);
  }

  li { margin-bottom: 0.25rem; }

  /* ── Tables ─────────────────────────────────────────────────────────────── */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.875rem;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  thead {
    background: var(--bg);
  }

  th {
    text-align: left;
    padding: 0.75rem 1rem;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    border-bottom: 2px solid var(--border);
  }

  td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }

  tbody tr {
    transition: background 0.15s;
  }

  tbody tr:hover {
    background: rgba(232, 160, 32, 0.04);
  }

  /* ── Article container ──────────────────────────────────────────────────── */
  article {
    max-width: 1000px;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  /* ── Incident metadata grid ─────────────────────────────────────────────── */
  .incident-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .meta-item {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 16px;
    border-radius: 4px;
  }

  /* ── Interactive meta boxes ────────────────────────────────────────────── */
  a.meta-item.meta-link {
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s, outline-color 0.2s;
    display: block;
  }

  a.meta-item.meta-link:hover {
    border-color: var(--amber-dim);
    outline: 1px solid var(--amber-dim);
    outline-offset: -1px;
  }

  a.meta-item.meta-link:hover .meta-value {
    color: var(--amber);
  }

  a.meta-item.meta-link-entity:hover {
    border-color: var(--amber);
    outline-color: var(--amber);
  }

  /* CVE links within meta boxes */
  .meta-cve-link {
    color: var(--amber);
    text-decoration: none;
    transition: color 0.15s;
  }

  .meta-cve-link:hover {
    color: var(--white);
    text-decoration: underline;
  }

  .meta-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    color: var(--muted);
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    display: block;
  }

  .meta-value {
    font-size: 14px;
    font-weight: 500;
    color: var(--white);
    transition: color 0.15s;
  }

  /* ── DL fallback (used by threat actors, zero-days) ─────────────────────── */
  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    margin: 1rem 0;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  dt {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  dd {
    color: var(--white);
    font-size: 14px;
    font-weight: 500;
  }

  /* ── Severity badges ────────────────────────────────────────────────────── */
  .severity {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 3px 8px;
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .severity.critical {
    color: var(--severity-critical);
    border-color: var(--severity-critical);
    background: rgba(255, 68, 68, 0.08);
  }

  .severity.high {
    color: var(--severity-high);
    border-color: var(--severity-high);
    background: rgba(255, 165, 0, 0.08);
  }

  .severity.medium {
    color: var(--severity-medium);
    border-color: var(--severity-medium);
    background: rgba(232, 160, 32, 0.08);
  }

  .severity.low {
    color: var(--severity-low);
    border-color: var(--severity-low);
    background: rgba(81, 207, 102, 0.08);
  }

  /* ── Incident / article headers ─────────────────────────────────────────── */
  .incident-header, article > header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .incident-id, .exploit-id {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--amber);
    background: rgba(232, 160, 32, 0.1);
    padding: 0.25em 0.6em;
    border: 1px solid rgba(232, 160, 32, 0.25);
  }

  .cve {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--severity-high);
    background: rgba(255, 165, 0, 0.1);
    padding: 0.25em 0.6em;
    border: 1px solid rgba(255, 165, 0, 0.2);
  }

  .review-status {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--surface);
    padding: 0.25em 0.6em;
    border: 1px solid var(--border);
  }

  /* ── Tags ────────────────────────────────────────────────────────────────── */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--surface);
    padding: 0.25em 0.6em;
    border: 1px solid var(--border);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    cursor: pointer;
  }

  a.tag:hover {
    color: var(--amber);
    border-color: var(--amber-dim);
  }

  /* ── Tech box (code highlights in articles) ─────────────────────────────── */
  .tech-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--amber);
    padding: 16px;
    margin: 16px 0;
    border-radius: 4px;
  }

  .tech-box strong { color: var(--white); }

  /* ── Timeline ───────────────────────────────────────────────────────────── */
  .timeline {
    position: relative;
    margin: 32px 0;
  }

  .timeline-item {
    display: flex;
    gap: 24px;
    margin-bottom: 24px;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 32px;
    width: 1px;
    height: calc(100% + 24px);
    background: var(--border);
  }

  .timeline-item:last-child::before { display: none; }

  .timeline-dot {
    width: 14px;
    height: 14px;
    background: var(--amber);
    border: 2px solid var(--bg);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 2px;
    box-shadow: 0 0 0 3px var(--surface);
  }

  .timeline-content { padding-top: 2px; flex-grow: 1; }

  .timeline-date {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .timeline-title {
    font-weight: 600;
    color: var(--white);
    margin-bottom: 4px;
  }

  .timeline-description {
    font-size: 14px;
    color: var(--text);
    line-height: 1.6;
  }

  /* ── Attack flow ────────────────────────────────────────────────────────── */
  .attack-flow {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 24px 0;
  }

  .attack-stage {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--amber);
    padding: 16px;
    border-radius: 4px;
  }

  .attack-stage-title {
    font-weight: 600;
    color: var(--amber);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .attack-stage-content {
    font-size: 14px;
    color: var(--text);
    line-height: 1.6;
  }

  .attack-stage-content ul { margin-left: 20px; margin-top: 8px; }
  .attack-stage-content li { margin-bottom: 6px; }

  /* ── IOC groups ─────────────────────────────────────────────────────────── */
  .ioc-group {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 16px;
    margin: 16px 0;
    border-radius: 4px;
  }

  .ioc-group-title {
    font-weight: 600;
    color: var(--amber);
    margin-bottom: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ioc-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ioc-item {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text);
    word-break: break-all;
    padding: 8px;
    background: var(--bg);
    border-radius: 2px;
  }

  /* ── References ─────────────────────────────────────────────────────────── */
  .references {
    margin: 48px 0;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .references-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: -0.3px;
  }

  .references-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .reference-item {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text);
  }

  .reference-item a { color: var(--amber); word-break: break-all; }
  .reference-item a:hover { text-decoration: underline; }

  .reference-num {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--amber);
    margin-right: 4px;
  }

  /* ── Sidebar ────────────────────────────────────────────────────────────── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar-box {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 20px;
    border-radius: 4px;
  }

  .sidebar-title {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    letter-spacing: -0.3px;
  }

  .sidebar-link {
    display: block;
    padding: 10px 0;
    color: var(--text);
    text-decoration: none;
    font-size: 13px;
    line-height: 1.5;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }

  .sidebar-link:last-child { border-bottom: none; }
  .sidebar-link:hover { color: var(--amber); }
  .sidebar-link::before { content: '\2192 '; color: var(--amber); margin-right: 4px; }

  .sidebar-content {
    font-size: 13px;
    color: var(--text);
    line-height: 1.6;
  }

  /* ── Home page sections ─────────────────────────────────────────────────── */
  section {
    margin-bottom: 3rem;
  }

  section > p {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  section > ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  section > ul > li {
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  section > ul > li .severity {
    margin-left: auto;
  }

  section > a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--amber);
    transition: color 0.2s;
  }

  section > a:hover { color: #f0b030; text-decoration: none; }

  /* ── Content grid (article + sidebar) ───────────────────────────────────── */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    margin-bottom: 48px;
  }

  .main-content { min-width: 0; }

  .content {
    margin-top: 1.5rem;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .content h2:first-child {
    margin-top: 0;
  }

  .content p {
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .content ul, .content ol {
    margin: 1rem 0 1.5rem 1.5rem;
  }

  .content blockquote {
    border-left: 3px solid var(--amber);
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border-radius: 0 4px 4px 0;
    color: var(--text);
    overflow-x: auto;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .content blockquote p {
    margin-bottom: 0.5rem;
  }

  .content blockquote p:last-child {
    margin-bottom: 0;
  }

  .content pre {
    max-width: 100%;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .content pre code {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .content h3 {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .content table {
    display: block;
    overflow-x: auto;
    max-width: 100%;
  }

  .content img {
    max-width: 100%;
    height: auto;
  }

  /* ── Attack Chain Stages ──────────────────────────────────────────────── */
  .attack-flow {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 24px 0;
  }

  .attack-stage {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--amber);
    padding: 16px;
    border-radius: 4px;
  }

  .attack-stage-title {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .attack-stage-content {
    font-size: 14px;
    color: var(--text);
    line-height: 1.7;
  }

  .attack-stage-content ul {
    margin-left: 20px;
    margin-top: 8px;
  }

  .attack-stage-content li {
    margin-bottom: 6px;
  }

  /* ── MITRE ATT&CK Technique Grid ─────────────────────────────────────── */
  .mitre-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 16px 0;
  }

  a.mitre-technique,
  .mitre-technique {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color 0.15s;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  a.mitre-technique:hover,
  .mitre-technique:hover {
    border-color: var(--amber);
    text-decoration: none;
  }

  .mitre-tid {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--amber);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 90px;
  }

  .mitre-name {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.5;
  }

  /* ── Timeline entries ────────────────────────────────────────────────── */
  .timeline-flow {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 24px 0;
    border-left: 2px solid var(--border);
    padding-left: 0;
  }

  .timeline-entry {
    position: relative;
    padding: 16px 0 16px 24px;
    border-bottom: 1px solid var(--border);
  }

  .timeline-entry:last-child {
    border-bottom: none;
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 22px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--amber);
    border: 2px solid var(--bg);
  }

  .timeline-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 4px;
  }

  .timeline-title {
    font-weight: 500;
    color: var(--white);
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .timeline-desc {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.6;
  }

  /* ── IOC Signature Items ─────────────────────────────────────────────── */
  .ioc-signatures {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 16px 0;
  }

  .ioc-sig-item {
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--severity-high);
    border-radius: 4px;
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.5;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  /* ── IOC Source Items ──────────────────────────────────────────────── */
  .ioc-sources {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 16px 0;
  }

  .ioc-source-item {
    display: flex;
    gap: 12px;
    align-items: baseline;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--amber);
    border-radius: 4px;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .ioc-source-name {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--amber);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ioc-source-desc {
    color: var(--text);
    font-size: 0.82rem;
  }

  /* ── Sources / References List ───────────────────────────────────────── */
  .sources-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 16px 0;
  }

  .source-item {
    display: flex;
    gap: 12px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    align-items: flex-start;
  }

  .source-num {
    font-family: var(--font-mono);
