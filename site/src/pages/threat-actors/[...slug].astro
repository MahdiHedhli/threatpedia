---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const actors = await getCollection('threat-actors');
  return actors.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.name}>
  <article>
    <h1>{entry.data.name}</h1>
    <div class="meta">
      <dl>
        <dt>Aliases</dt><dd>{entry.data.aliases.join(', ') || 'None'}</dd>
        <dt>Affiliation</dt><dd>{entry.data.affiliation}</dd>
        <dt>Motivation</dt><dd>{entry.data.motivation}</dd>
        <dt>Status</dt><dd>{entry.data.status}</dd>
      </dl>
    </div>
    <div class="content">
      <Content />
    </div>
  </article>
</Base>
