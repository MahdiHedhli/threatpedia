---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { resolveGeoPoints, summarizeGeo, type GeoPoint } from '../lib/geo';
import { WORLD_LAND_PATHS, WORLD_MAP_VIEWBOX } from '../lib/worldMapPaths';

type AttackType = 'incident' | 'campaign' | 'zero-day';

interface AttackRecord {
  title: string;
  href: string;
  type: AttackType;
  date: Date;
  severity: string;
  geography: string;
  descriptor: string;
}

interface MapAttack extends AttackRecord {
  index: number;
  dateLabel: string;
  typeLabel: string;
  geoLabel: string;
  point: GeoPoint;
  x: number;
  y: number;
}

interface IntelItem {
  title: string;
  date: string;
  href: string;
  type: string;
  severity?: string;
  tags: string[];
}

const [incidents, campaigns, actors, zeroDays] = await Promise.all([
  getCollection('incidents'),
  getCollection('campaigns'),
  getCollection('threat-actors'),
  getCollection('zero-days'),
]);

const map = WORLD_MAP_VIEWBOX;

const globalAnchors: GeoPoint[] = [
  { label: 'Global', lat: 47, lon: -130, kind: 'global' },
  { label: 'Global', lat: 18, lon: -58, kind: 'global' },
  { label: 'Global', lat: 52, lon: 12, kind: 'global' },
  { label: 'Global', lat: 22, lon: 82, kind: 'global' },
  { label: 'Global', lat: -22, lon: 135, kind: 'global' },
  { label: 'Global', lat: -16, lon: -65, kind: 'global' },
];

const attackRecords: AttackRecord[] = [
  ...incidents.map((entry) => ({
    title: entry.data.title,
    href: `/incidents/${entry.id}/`,
    type: 'incident' as const,
    date: entry.data.date,
    severity: entry.data.severity,
    geography: entry.data.geography,
    descriptor: entry.data.attackType,
  })),
  ...campaigns.map((entry) => ({
    title: entry.data.title,
    href: `/campaigns/${entry.id}/`,
    type: 'campaign' as const,
    date: entry.data.endDate || entry.data.startDate,
    severity: entry.data.severity,
    geography: entry.data.geography,
    descriptor: entry.data.attackType,
  })),
  ...zeroDays.map((entry) => ({
    title: entry.data.title,
    href: `/zero-days/${entry.id}/`,
    type: 'zero-day' as const,
    date: entry.data.disclosedDate || entry.data.patchDate || entry.data.generatedDate,
    severity: entry.data.severity,
    geography: 'Global',
    descriptor: entry.data.platform,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

const latestAttacks: MapAttack[] = attackRecords.slice(0, 15).map((attack, index) => {
  const points = resolveGeoPoints(attack.geography);
  const geoLabel = summarizeGeo(points, attack.geography);
  const point = points[0].kind === 'global' || points[0].kind === 'unknown'
    ? { ...globalAnchors[index % globalAnchors.length], kind: points[0].kind }
    : points[0];
  const projected = project(point.lat, point.lon, index);

  return {
    ...attack,
    index,
    dateLabel: attack.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
    typeLabel: typeLabel(attack.type),
    geoLabel,
    point,
    x: projected.x,
    y: projected.y,
  };
});

const newest = latestAttacks[0];
const oldest = latestAttacks[latestAttacks.length - 1];
const latitudeLines = [-60, -30, 0, 30, 60].map((lat) => ({ lat, y: project(lat, 0, 0, false).y }));
const longitudeLines = [-120, -60, 0, 60, 120].map((lon) => ({ lon, x: project(0, lon, 0, false).x }));
const severityCounts = latestAttacks.reduce<Record<string, number>>((counts, attack) => {
  counts[attack.severity] = (counts[attack.severity] || 0) + 1;
  return counts;
}, {});

const publicAttackData = latestAttacks.map((attack) => ({
  index: attack.index,
  title: attack.title,
  href: attack.href,
  typeLabel: attack.typeLabel,
  dateLabel: attack.dateLabel,
  severity: attack.severity,
  geoLabel: attack.geoLabel,
  descriptor: attack.descriptor,
  x: attack.x,
  y: attack.y,
}));

const latestIntel: IntelItem[] = [];

incidents.forEach((entry) => {
  const date = entry.data.date || new Date();
  latestIntel.push({
    title: entry.data.title,
    date: date instanceof Date ? date.toISOString() : date,
    href: `/incidents/${entry.id}/`,
    type: 'INCIDENT',
    severity: entry.data.severity,
    tags: [entry.data.attackType, entry.data.sector].filter((tag) => tag && tag.toLowerCase() !== 'unknown'),
  });
});

campaigns.forEach((entry) => {
  const date = entry.data.startDate || new Date();
  latestIntel.push({
    title: entry.data.title,
    date: date instanceof Date ? date.toISOString() : date,
    href: `/campaigns/${entry.id}/`,
    type: 'CAMPAIGN',
    severity: entry.data.severity,
    tags: [entry.data.sector].filter((tag) => tag && tag.toLowerCase() !== 'unknown'),
  });
});

actors.forEach((entry) => {
  const date = entry.data.lastSeen || entry.data.firstSeen || '2000-01-01';
  latestIntel.push({
    title: entry.data.name,
    date: date.length === 4 ? `${date}-01-01` : date.length === 7 ? `${date}-01` : date,
    href: `/threat-actors/${entry.id}/`,
    type: 'THREAT ACTOR',
    severity: 'high',
    tags: [entry.data.affiliation, entry.data.motivation].filter((tag) => tag && tag.toLowerCase() !== 'unknown'),
  });
});

zeroDays.forEach((entry) => {
  const date = entry.data.disclosedDate || entry.data.generatedDate || new Date();
  latestIntel.push({
    title: entry.data.title,
    date: date instanceof Date ? date.toISOString() : date,
    href: `/zero-days/${entry.id}/`,
    type: 'ZERO-DAY',
    severity: entry.data.severity,
    tags: [entry.data.platform, entry.data.status].filter((tag) => tag && tag.toLowerCase() !== 'unknown'),
  });
});

latestIntel.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function project(lat: number, lon: number, index: number, jitter = true) {
  const rawX = ((lon + 180) / 360) * map.width;
  const rawY = ((90 - lat) / 180) * map.height;
  const offset = jitter ? ((index % 5) - 2) * 3.5 : 0;

  return {
    x: Math.round(clamp(rawX + offset, 18, map.width - 18) * 10) / 10,
    y: Math.round(clamp(rawY - offset, 18, map.height - 18) * 10) / 10,
  };
}

function clamp(value: number, min: number, max: number) {
  return Math.min(max, Math.max(min, value));
}

function typeLabel(type: AttackType) {
  if (type === 'zero-day') return 'Zero-day';
  if (type === 'campaign') return 'Campaign';
  return 'Incident';
}
---

<Base title="Home">
  <section class="map-hero" data-homepage-map>
    <div class="hero-copy">
      <div class="hero-eyebrow">Threat Intelligence &middot; Historical Record &middot; Peer Reviewed</div>
      <h1 class="hero-title">The <em>Cyber Threat</em><br/>Encyclopedia</h1>
      <div class="hero-sub">Building an open, structured record of cyber history</div>
    </div>

    <div class="map-feature">
      <div class="map-card">
        <div class="map-card-head">
          <div>
            <span>Last 15 attacks</span>
            <strong>{oldest?.dateLabel} to {newest?.dateLabel}</strong>
          </div>
          <div class="map-metrics" aria-label="Latest attack map metrics">
            <span>{latestAttacks.length} records</span>
            <span>{Object.keys(severityCounts).length} severity bands</span>
          </div>
        </div>

        <svg class="attack-map" viewBox={`0 0 ${map.width} ${map.height}`} role="img" aria-labelledby="home-map-title home-map-desc">
          <title id="home-map-title">Latest attacks mapped on a Threatpedia world map</title>
          <desc id="home-map-desc">The latest 15 corpus attack records are plotted by recorded geography and highlighted one at a time.</desc>
          <defs>
            <linearGradient id="home-map-fill" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#111924" />
              <stop offset="58%" stop-color="#0b1118" />
              <stop offset="100%" stop-color="#06080c" />
            </linearGradient>
            <filter id="home-pin-glow" x="-80%" y="-80%" width="260%" height="260%">
              <feGaussianBlur stdDeviation="4" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>

          <rect class="map-ocean" x="0" y="0" width={map.width} height={map.height} rx="18" />
          <g class="map-grid" aria-hidden="true">
            {longitudeLines.map((line) => <line x1={line.x} y1="0" x2={line.x} y2={map.height} />)}
            {latitudeLines.map((line) => <line x1="0" y1={line.y} x2={map.width} y2={line.y} />)}
          </g>
          <g class="land-masses" aria-hidden="true">
            {WORLD_LAND_PATHS.map((path) => <path d={path} />)}
          </g>
          <rect class="map-border" x="0.5" y="0.5" width={map.width - 1} height={map.height - 1} rx="18" />
          <line
            class="active-spoke"
            data-active-spoke
            x1={map.width / 2}
            y1={map.height / 2}
            x2={newest?.x}
            y2={newest?.y}
          />
          <g class="attack-pins">
            {latestAttacks.map((attack) => (
              <a
                href={attack.href}
                class={`map-pin severity-${attack.severity}${attack.index === 0 ? ' is-active' : ''}`}
                data-attack-index={attack.index}
                data-x={attack.x}
                data-y={attack.y}
                aria-label={`${attack.index + 1}. ${attack.title}, ${attack.dateLabel}, ${attack.geoLabel}`}
              >
                <circle class="pin-pulse" cx={attack.x} cy={attack.y} r="16" />
                <circle class="pin-hit" cx={attack.x} cy={attack.y} r="15" />
                <circle class="pin-dot" cx={attack.x} cy={attack.y} r="5.5" />
                <text x={attack.x} y={attack.y - 19}>{String(attack.index + 1).padStart(2, '0')}</text>
              </a>
            ))}
          </g>
        </svg>

        <div class="active-readout">
          <div class="readout-meta">
            <span data-active-type>{newest?.typeLabel}</span>
            <span data-active-date>{newest?.dateLabel}</span>
            <span data-active-geo>{newest?.geoLabel}</span>
          </div>
          <a href={newest?.href} data-active-title>{newest?.title}</a>
          <p data-active-detail>{newest?.descriptor} / {newest?.severity}</p>
        </div>
      </div>

      <aside class="attack-panel" aria-label="Latest 15 attack records">
        <div class="panel-head">
          <span>Latest attacks</span>
          <strong>By corpus date</strong>
        </div>
        <div class="attack-list" tabindex="0" aria-label="Scrollable list of latest attacks">
          {latestAttacks.map((attack) => (
            <a
              href={attack.href}
              class={`attack-row severity-${attack.severity}${attack.index === 0 ? ' is-active' : ''}`}
              data-attack-row
              data-attack-index={attack.index}
            >
              <span class="attack-rank">{String(attack.index + 1).padStart(2, '0')}</span>
              <span class="attack-copy">
                <span class="attack-title">{attack.title}</span>
                <span class="attack-meta">{attack.dateLabel} / {attack.typeLabel} / {attack.geoLabel}</span>
              </span>
              <span class="attack-severity">{attack.severity}</span>
            </a>
          ))}
        </div>
      </aside>
    </div>

    <div class="hero-support">
      <div class="phase-disclosure">
        <div class="phase-disclosure-headline">
          <span class="phase-disclosure-dot" aria-hidden="true"></span>
          <strong>Phase 0 &mdash; in active development.</strong>
        </div>
        <div class="phase-disclosure-body">
          Every article carries its review status. New entries are AI-drafted and peer-reviewed before certification.
        </div>
        <a class="phase-disclosure-link" href="/roadmap/#how-we-verify">How we verify &rarr;</a>
      </div>

      <div class="stats-bar">
        <a href="/incidents/" class="stat" aria-label="Browse incidents">
          <div class="stat-value">{incidents.length}</div>
          <div class="stat-label">Events Catalogued</div>
        </a>
        <a href="/campaigns/" class="stat" aria-label="Browse campaigns">
          <div class="stat-value">{campaigns.length}</div>
          <div class="stat-label">Campaigns Tracked</div>
        </a>
        <a href="/threat-actors/" class="stat" aria-label="Browse threat actors">
          <div class="stat-value">{actors.length}</div>
          <div class="stat-label">APT Groups Tracked</div>
        </a>
        <a href="/zero-days/" class="stat" aria-label="Browse zero-days">
          <div class="stat-value">{zeroDays.length}</div>
          <div class="stat-label">Zero-Days Tracked</div>
        </a>
      </div>
    </div>
  </section>

  <div class="ticker">
    <div class="ticker-item">Peer-Reviewed Articles</div>
    <div class="ticker-item">MITRE ATT&CK Mapping</div>
    <div class="ticker-item">APT Registry</div>
    <div class="ticker-break"></div>
    <div class="ticker-item">STIX/TAXII Support (Soon)</div>
    <div class="ticker-item">AI-Augmented Review</div>
    <div class="ticker-item">Open Research Access</div>
  </div>

  <section class="pillars">
    <div class="section-hdr">
      <span class="section-tag">What We're Building</span>
      <div class="section-line"></div>
    </div>
    <div class="pillars-grid">
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// 01</div>
        <h3>Incident Encyclopedia</h3>
        <p>Every significant cyber event documented with standardized data points &mdash; TTPs, timeline, attribution, impact, affected sectors, and source citations.</p>
      </a>
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// 02</div>
        <h3>APT Registry</h3>
        <p>Current and historical Advanced Persistent Threat groups tracked with profiles, known campaigns, tooling, state affiliation, and activity timelines.</p>
      </a>
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// 03</div>
        <h3>Framework Mapping</h3>
        <p>Incidents mapped to MITRE ATT&CK, NIST, Cyber Kill Chain, and more &mdash; enabling cross-incident trend analysis and data-driven research.</p>
      </a>
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// 04</div>
        <h3>Peer Review &amp; Certification</h3>
        <p>A board of cyber historians, reporters, and SMEs reviews submissions. Approved articles earn the Threatpedia seal &mdash; a mark of verified accuracy.</p>
      </a>
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// 05</div>
        <h3>Trend Analytics</h3>
        <p>Structured data across all incidents enables trend analysis by sector, vector, actor type, geography, and time &mdash; powering original research.</p>
      </a>
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// 06</div>
        <h3>AI-Augmented Workflow</h3>
        <p>AI assists with aggregating news sources, flagging potential incidents, pre-screening articles, and surfacing related events &mdash; accelerating human reviewers.</p>
      </a>
    </div>
  </section>

  <section class="pillars is-live-resources">
    <div class="section-hdr">
      <span class="section-tag">Live Resources &mdash; Available Now</span>
      <div class="section-line"></div>
    </div>
    <div class="pillars-grid">
      <a href="/incidents/" class="pillar">
        <div class="pillar-num">// LIVE</div>
        <h3>Incident Reports</h3>
        <p>In-depth intelligence dossiers on major cyber incidents &mdash; from supply chain attacks to nation-state operations. Full IOCs, timelines, and remediation guidance.</p>
      </a>
      <a href="/campaigns/" class="pillar">
        <div class="pillar-num">// LIVE</div>
        <h3>Campaign Dossiers</h3>
        <p>Ongoing multi-event operations and persistent threat campaigns &mdash; tracked with attribution, TTPs, related incidents, and timeline data.</p>
      </a>
      <a href="/threat-actors/" class="pillar">
        <div class="pillar-num">// LIVE</div>
        <h3>Threat Actor Registry</h3>
        <p>{actors.length} tracked APT groups with cross-vendor naming, nation-state attribution, known campaigns, and associated tooling. Filterable and searchable.</p>
      </a>
      <a href="/zero-days/" class="pillar">
        <div class="pillar-num">// LIVE</div>
        <h3>Zero-Day Exploits</h3>
        <p>{zeroDays.length} tracked zero-day vulnerabilities with CVEs, platform details, patch status, and links to related incidents and threat actors.</p>
      </a>
      <a href="/glossary/" class="pillar">
        <div class="pillar-num">// LIVE</div>
        <h3>Glossary</h3>
        <p>1,000+ cybersecurity terms defined and tagged by role &mdash; from SOC analysts to CISOs. Searchable, filterable, and continuously expanding.</p>
      </a>
      <a href="/roadmap/" class="pillar">
        <div class="pillar-num">// LIVE</div>
        <h3>Roadmap</h3>
        <p>Where Threatpedia is headed &mdash; planned features, framework integrations, data pipeline milestones, and community tools. Updated in real time.</p>
      </a>
    </div>
  </section>

  <section class="recent-incidents">
    <div class="section-hdr">
      <span class="section-tag">Latest Threat Intel</span>
      <div class="section-line"></div>
    </div>
    <div class="incidents-grid">
      {latestIntel.slice(0, 6).map((item) => (
        <a href={item.href} class="incident-card">
          <div class="incident-card-header">
            <div class="incident-card-date">
              {new Date(item.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </div>
            <div class="incident-card-badges">
              <span class={`badge badge-type-${item.type.toLowerCase().replace(/\s+/g, '-')}`}>{item.type}</span>
              {item.severity && (
                <span class={`badge badge-${item.severity}`}>{item.severity}</span>
              )}
            </div>
          </div>
          <h3>{item.title}</h3>
          <div class="incident-card-meta">
            {item.tags.map((tag) => (
              <span class="incident-card-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <script type="application/json" id="homepage-map-data" set:html={JSON.stringify(publicAttackData)} />
  <script is:inline>
    (() => {
      const root = document.querySelector('[data-homepage-map]');
      const dataEl = document.getElementById('homepage-map-data');
      if (!root || !dataEl) return;

      const attacks = JSON.parse(dataEl.textContent || '[]');
      const pins = [...root.querySelectorAll('.map-pin')];
      const rows = [...root.querySelectorAll('[data-attack-row]')];
      const list = root.querySelector('.attack-list');
      const spoke = root.querySelector('[data-active-spoke]');
      const title = root.querySelector('[data-active-title]');
      const type = root.querySelector('[data-active-type]');
      const date = root.querySelector('[data-active-date]');
      const geo = root.querySelector('[data-active-geo]');
      const detail = root.querySelector('[data-active-detail]');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let activeIndex = 0;
      let timer = null;

      function syncAttackList(index) {
        if (!list || !list.clientHeight) return;
        const activeRow = rows.find((node) => Number(node.dataset.attackIndex) === index);
        if (!activeRow || !activeRow.offsetHeight) return;

        const rowsPerPanel = Math.max(1, Math.floor(list.clientHeight / activeRow.offsetHeight));
        const pageStart = Math.floor(index / rowsPerPanel) * rowsPerPanel;
        const pageRow = rows.find((node) => Number(node.dataset.attackIndex) === pageStart);
        if (!pageRow) return;

        const maxScrollTop = Math.max(0, list.scrollHeight - list.clientHeight);
        const targetTop = Math.min(pageRow.offsetTop, maxScrollTop);
        if (Math.abs(list.scrollTop - targetTop) < 4) return;

        list.scrollTo({
          top: targetTop,
          behavior: reduceMotion ? 'auto' : 'smooth',
        });
      }

      function setActive(index) {
        const attack = attacks[index];
        if (!attack) return;
        activeIndex = index;

        pins.forEach((node) => node.classList.toggle('is-active', Number(node.dataset.attackIndex) === index));
        rows.forEach((node) => node.classList.toggle('is-active', Number(node.dataset.attackIndex) === index));
        syncAttackList(index);

        if (spoke) {
          spoke.setAttribute('x2', attack.x);
          spoke.setAttribute('y2', attack.y);
        }
        if (title) {
          title.textContent = attack.title;
          title.setAttribute('href', attack.href);
        }
        if (type) type.textContent = attack.typeLabel;
        if (date) date.textContent = attack.dateLabel;
        if (geo) geo.textContent = attack.geoLabel;
        if (detail) detail.textContent = `${attack.descriptor} / ${attack.severity}`;
      }

      function startCycle() {
        if (reduceMotion || timer || attacks.length < 2) return;
        timer = window.setInterval(() => setActive((activeIndex + 1) % attacks.length), 2600);
      }

      function stopCycle() {
        if (!timer) return;
        window.clearInterval(timer);
        timer = null;
      }

      pins.concat(rows).forEach((node) => {
        node.addEventListener('mouseenter', () => {
          stopCycle();
          setActive(Number(node.dataset.attackIndex));
        });
        node.addEventListener('focus', () => {
          stopCycle();
          setActive(Number(node.dataset.attackIndex));
        });
      });

      root.addEventListener('mouseleave', startCycle);
      startCycle();
    })();
  </script>
</Base>

<style>
  .map-hero {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    padding: 18px 0 36px;
  }

  .hero-copy {
    width: 100%;
    max-width: none;
    margin-bottom: 30px;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero-eyebrow::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--amber);
    flex-shrink: 0;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(3.7rem, 8.4vw, 7.25rem);
    line-height: 0.95;
    color: var(--white);
    margin-bottom: 18px;
    border-bottom: none;
    padding-bottom: 0;
  }

  .hero-title em {
    color: var(--amber);
    font-style: italic;
  }

  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--border);
    max-width: none;
    margin-top: 18px;
  }

  .stat {
    flex: 1;
    padding: 20px 22px;
    border-right: 1px solid var(--border);
    display: block;
    color: inherit;
    text-decoration: none;
    transition: background 0.2s;
  }

  .stat:last-child {
    border-right: 0;
  }

  .stat:hover {
    background: rgba(232, 160, 32, 0.04);
    outline: 1px solid var(--amber-dim);
    outline-offset: -1px;
    text-decoration: none;
  }

