---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const zeroDays = await getCollection('zero-days');
  return zeroDays.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title}>
  <article>
    <header>
      <span class="exploit-id">{entry.data.exploitId}</span>
      <span class="cve">{entry.data.cve}</span>
      <span class={`severity ${entry.data.severity}`}>{entry.data.severity}</span>
    </header>
    <h1>{entry.data.title}</h1>
    <div class="meta">
      <dl>
        <dt>Platform</dt><dd>{entry.data.platform}</dd>
        <dt>Type</dt><dd>{entry.data.type}</dd>
        <dt>Status</dt><dd>{entry.data.status}</dd>
        <dt>Zero-Day</dt><dd>{entry.data.isZeroDay ? 'Yes' : 'No'}</dd>
        <dt>CISA KEV</dt><dd>{entry.data.cisaKev ? 'Yes' : 'No'}</dd>
      </dl>
    </div>
    <div class="content">
      <Content />
    </div>
  </article>
</Base>
