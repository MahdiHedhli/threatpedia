---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const incidents = await getCollection('incidents');
incidents.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Incidents">
  <h1>Incidents</h1>
  <p>{incidents.length} cybersecurity incidents tracked</p>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Date</th>
        <th>Severity</th>
        <th>Attack Type</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {incidents.map((incident) => (
        <tr>
          <td>{incident.data.eventId}</td>
          <td><a href={`/incidents/${incident.id}/`}>{incident.data.title}</a></td>
          <td>{new Date(incident.data.date).toLocaleDateString('en-US')}</td>
          <td><span class={`severity ${incident.data.severity}`}>{incident.data.severity}</span></td>
          <td>{incident.data.attackType}</td>
          <td>{incident.data.reviewStatus}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
