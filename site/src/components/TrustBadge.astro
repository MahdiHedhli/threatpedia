---
/**
 * TrustBadge — renders the review status of an article as a color-coded
 * pill that links to the "How We Verify" section of the public roadmap.
 *
 * Per DATA-STANDARDS v1.0, every article in the corpus carries a
 * `reviewStatus` value from the enum { draft_ai, draft_human, under_review,
 * certified, disputed, deprecated }. This component surfaces that value
 * prominently so practitioners can quickly gauge how much human verification
 * has been applied to the content they're reading.
 *
 * Confidence grade (A–F) is rendered alongside when available.
 *
 * Usage:
 *   <TrustBadge status={frontmatter.reviewStatus} confidence={frontmatter.confidenceGrade} />
 */

export interface Props {
  status: string;
  confidence?: string;
}

const { status, confidence } = Astro.props;

const STATUS_META: Record<string, { label: string; tone: string; description: string }> = {
  draft_ai: {
    label: 'AI Draft',
    tone: 'draft',
    description: 'Generated by an automated pipeline. Has not been reviewed by a human editor.',
  },
  draft_human: {
    label: 'Human Draft',
    tone: 'draft',
    description: 'Written or significantly revised by a human contributor. Not yet peer-reviewed.',
  },
  under_review: {
    label: 'Under Review',
    tone: 'review',
    description: 'Actively being verified by an editor or peer reviewer. Facts and attribution subject to change.',
  },
  certified: {
    label: 'Certified',
    tone: 'certified',
    description: 'Reviewed and verified to meet Threatpedia data standards. Safe to cite.',
  },
  disputed: {
    label: 'Disputed',
    tone: 'disputed',
    description: 'A reviewer has flagged significant factual or interpretive concerns. Read with scrutiny.',
  },
  deprecated: {
    label: 'Deprecated',
    tone: 'deprecated',
    description: 'Superseded by a newer article or removed from the active corpus. Kept for audit trail.',
  },
};

const meta = STATUS_META[status] ?? {
  label: status,
  tone: 'draft',
  description: 'Review status not in the canonical taxonomy. Treat as unreviewed.',
};
---

<a
  class={`trust-badge trust-badge-${meta.tone}`}
  href="/roadmap/#how-we-verify"
  title={meta.description}
  aria-label={`Review status: ${meta.label}. ${meta.description}`}
>
  <span class="trust-badge-dot" aria-hidden="true"></span>
  <span class="trust-badge-label">{meta.label}</span>
  {confidence && (
    <span class="trust-badge-confidence" title={`Confidence grade: ${confidence}`}>
      {confidence}
    </span>
  )}
</a>

<style>
  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px 4px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--surface);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .trust-badge:hover {
    border-color: var(--amber-dim);
    color: var(--white);
    background: rgba(232, 160, 32, 0.04);
  }

  .trust-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .trust-badge-label {
    font-weight: 500;
  }

  .trust-badge-confidence {
    padding: 0 5px;
    margin-left: 2px;
    border-left: 1px solid var(--border);
    color: var(--muted);
    font-weight: 400;
  }

  /* ── Tone-specific accents ──────────────────────────────────────────── */
  .trust-badge-draft .trust-badge-dot {
    background: var(--muted);
  }

  .trust-badge-review .trust-badge-dot {
    background: var(--amber);
    box-shadow: 0 0 6px rgba(232, 160, 32, 0.4);
  }

  .trust-badge-review {
    color: var(--amber);
    border-color: rgba(232, 160, 32, 0.3);
  }

  .trust-badge-certified .trust-badge-dot {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.4);
  }

  .trust-badge-certified {
    color: #22c55e;
    border-color: rgba(34, 197, 94, 0.3);
  }

  .trust-badge-disputed .trust-badge-dot {
    background: #ff4444;
    box-shadow: 0 0 6px rgba(255, 68, 68, 0.4);
  }

  .trust-badge-disputed {
    color: #ff4444;
    border-color: rgba(255, 68, 68, 0.3);
  }

  .trust-badge-deprecated .trust-badge-dot {
    background: #6b7280;
  }

  .trust-badge-deprecated {
    color: #6b7280;
    opacity: 0.8;
  }
</style>
